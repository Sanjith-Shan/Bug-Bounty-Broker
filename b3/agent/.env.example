# --- sealed inside TEE (encrypted by Eigen KMS) ---

# AI Gateway (see docs/eigencloud-platform.md §2)
EIGEN_GATEWAY_URL=https://ai-gateway-dev.eigencloud.xyz
EIGEN_MODEL=anthropic/claude-sonnet-4.6
EIGEN_SEED=42
# Local-dev JWT for the AI Gateway. Request from #ext-private-preview.
# Inside EigenCompute, leave blank — the sidecar reads
# /run/container_launcher/attestation_verifier_claims_token automatically.
KMS_AUTH_JWT=

# MNEMONIC is auto-injected by EigenCompute. Set it manually only for local dev.
MNEMONIC="test test test test test test test test test test test junk"

# RPC endpoints. EigenCompute can reach these; for local dev use Alchemy/Infura/etc.
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: encrypt sqlite blobs at rest with a key derived from MNEMONIC if not set.
DB_PATH=/app/data/b3.db
WORK_DIR=/app/work

# --- visible externally (suffix _PUBLIC) ---
AGENT_ADDRESS_PUBLIC=0x0000000000000000000000000000000000000000
APP_DIGEST_PUBLIC=sha256:placeholder
SUPPORTED_CHAINS_PUBLIC=1,8453,84532,137
FEE_BPS_PUBLIC=500
DOMAIN=
APP_PORT=3000
